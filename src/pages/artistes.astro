---
import Layout from "../layouts/Layout.astro";
import { artistesName } from "../../backend/backend.mjs";

const PB_URL = "https://festicloze.sacha-martin.fr:443";

function formatDate(date: string) {
    const d = new Date(date);
    const jour = d.toLocaleDateString("fr-FR", {
        weekday: "long",
        day: "numeric",
        month: "long",
    });
    const heure = d.toLocaleTimeString("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    });
    return `${jour} à ${heure}`;
}

let artists: any[] = [];

try {
    const records = await artistesName();
    artists = records.map((artist: any) => ({
        id: artist.id,
        name: artist.nom_artiste,
        role: artist.genre_artiste,
        dates: artist.date_representation
            ? formatDate(artist.date_representation)
            : "Dates à confirmer",
        photoUrl: artist.photo_artiste
            ? `${PB_URL}/api/files/artiste/${artist.id}/${artist.photo_artiste}`
            : null,
    }));
} catch (error) {
    console.error("Erreur lors de la récupération des artistes:", error);
}

const genres = [...new Set(artists.map((a) => a.role).filter(Boolean))];

const title = "Artistes - Festicloze";
---

<Layout title={title}>
    <main class="bg-[#4A0E0E] min-h-screen">
        <section
            class="h-[140px] relative bg-[url('/src/assets/img/fond.avif')] bg-center bg-cover border-b border-[#D4AF37]/30"
        >
            <div class="absolute inset-0 bg-[#8B1538]/60 backdrop-blur-[1px]">
            </div>
        </section>

        <div class="max-w-6xl mx-auto px-6 py-12">
            <h2
                class="text-white font-serif text-4xl text-center mb-8 tracking-wide"
            >
                Artistes
            </h2>

            <div
                class="flex flex-wrap justify-center gap-3 mb-10"
                id="genre-filters"
            >
                <button
                    class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[var(--color-yellow)] text-[var(--color-red)]"
                    data-genre="all"
                >
                    Tous
                </button>
                {
                    genres.map((genre) => (
                        <button
                            class="filter-btn px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-white/20 text-white hover:bg-[var(--color-yellow)] hover:text-[var(--color-red)]"
                            data-genre={genre}
                        >
                            {genre}
                        </button>
                    ))
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                {
                    artists.map((artist) => (
                        <a
                            href={`/artistes/${artist.id}/`}
                            class="artist-card"
                            data-genre={artist.role || ""}
                        >
                            <div class="flex flex-col rounded-xl overflow-hidden shadow-lg transition-transform hover:scale-[1.02] cursor-pointer">
                                <div class="h-48 w-full overflow-hidden bg-gray-300">
                                    {artist.photoUrl && (
                                        <img
                                            src={artist.photoUrl}
                                            alt={artist.name}
                                            class="w-full h-full object-cover"
                                        />
                                    )}
                                </div>

                                <div class="bg-[#EBD5B3] p-5 flex flex-col gap-1 min-h-[120px]">
                                    <h3 class="text-[#8B1538] font-serif text-lg font-bold leading-tight">
                                        {artist.name}
                                    </h3>
                                    <p class="text-[#2D2D2D] text-sm font-medium">
                                        {artist.role}
                                    </p>
                                    <p class="text-[#2D2D2D] text-xs opacity-80">
                                        {artist.dates}
                                    </p>
                                </div>
                            </div>
                        </a>
                    ))
                }
            </div>
        </div>
    </main>
</Layout>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".artist-card");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            buttons.forEach((b) => {
                b.classList.remove("active");
                b.classList.remove(
                    "bg-[var(--color-yellow)]",
                    "text-[var(--color-red)]",
                );
                b.classList.add("bg-white/20", "text-white");
            });
            btn.classList.add("active");
            btn.classList.remove("bg-white/20", "text-white");
            btn.classList.add(
                "bg-[var(--color-yellow)]",
                "text-[var(--color-red)]",
            );

            const genre = btn.getAttribute("data-genre");

            cards.forEach((card) => {
                if (
                    genre === "all" ||
                    card.getAttribute("data-genre") === genre
                ) {
                    (card as HTMLElement).style.display = "";
                } else {
                    (card as HTMLElement).style.display = "none";
                }
            });
        });
    });
</script>
