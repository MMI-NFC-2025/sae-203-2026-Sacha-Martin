---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Artistes">
  <Header />
  
  <!-- Titre -->
  <section class="bg-rouge text-blanc text-center py-12 px-4">
    <h2 class="text-3xl font-bold">Artistes</h2>
  </section>

  <!-- Liste des artistes -->
  <section class="py-12 px-4 bg-gris">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <!-- Artiste 1 -->
      <div class="bg-blanc p-4 text-center">
        <img src="/images/ensemble-baroque.jpg" alt="Ensemble Baroque de Paris" class="w-full h-48 object-cover mb-4">
        <h3 class="text-xl font-bold text-rouge">Ensemble Baroque de Paris</h3>
        <p class="text-or">Direction musicale</p>
        <p class="text-sm mt-2">21 & 22 Decembre</p>
      </div>
      
      <!-- Artiste 2 -->
      <div class="bg-blanc p-4 text-center">
        <img src="/images/soprano.jpg" alt="Marie-Claire Dubois" class="w-full h-48 object-cover mb-4">
        <h3 class="text-xl font-bold text-rouge">Marie-Claire Dubois</h3>
        <p class="text-or">Soprano</p>
        <p class="text-sm mt-2">20 & 23 Decembre</p>
      </div>
      
      <!-- Artiste 3 -->
      <div class="bg-blanc p-4 text-center">
        <img src="/images/violoniste.jpg" alt="Antoine Lefevre" class="w-full h-48 object-cover mb-4">
        <h3 class="text-xl font-bold text-rouge">Antoine Lefevre</h3>
        <p class="text-or">Violon baroque</p>
        <p class="text-sm mt-2">21 & 23 Decembre</p>
      </div>
      
    </div>
  </section>

  <Footer />
</Layout>
