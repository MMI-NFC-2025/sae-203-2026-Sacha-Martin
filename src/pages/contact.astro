---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact">
  <Header />
  
  <!-- Titre -->
  <section class="bg-rouge text-blanc text-center py-12 px-4">
    <h2 class="text-3xl font-bold">Contact</h2>
  </section>

  <!-- Formulaire -->
  <section class="py-12 px-4 bg-gris">
    <div class="max-w-xl mx-auto bg-blanc p-6">
      
      <form>
        <!-- Nom -->
        <div class="mb-4">
          <label class="block mb-2 font-bold">Nom complet:</label>
          <input type="text" class="w-full p-2 border border-noir">
        </div>
        
        <!-- Email -->
        <div class="mb-4">
          <label class="block mb-2 font-bold">Adresse e-mail:</label>
          <input type="email" class="w-full p-2 border border-noir">
        </div>
        
        <!-- Objet -->
        <div class="mb-4">
          <label class="block mb-2 font-bold">Objet du message:</label>
          <select class="w-full p-2 border border-noir">
            <option>Billetterie</option>
            <option>Programme</option>
            <option>Autre</option>
          </select>
        </div>
        
        <!-- Message -->
        <div class="mb-4">
          <label class="block mb-2 font-bold">Message:</label>
          <textarea rows="5" class="w-full p-2 border border-noir"></textarea>
        </div>
        
        <!-- Bouton -->
        <button type="submit" class="bg-or text-noir px-6 py-3 font-bold hover:bg-rouge hover:text-blanc">
          Envoyer
        </button>
      </form>
      
    </div>
  </section>

  <Footer />
</Layout>
