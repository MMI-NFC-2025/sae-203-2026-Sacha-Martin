---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import egliseImage from "../assets/img/eglise.avif";
import FormField from "../components/FormField.astro";

interface FormField {
    id: string;
    name: string;
    type: "text" | "email" | "textarea";
    label: string;
    placeholder: string;
    required: boolean;
    rows?: number;
}

const formFields: FormField[] = [
    {
        id: "name",
        name: "name",
        type: "text",
        label: "Nom complet:",
        placeholder: "Entrez votre texte...",
        required: true,
    },
    {
        id: "email",
        name: "email",
        type: "email",
        label: "Adresse e-mail :",
        placeholder: "Entrez votre texte...",
        required: true,
    },
    {
        id: "subject",
        name: "subject",
        type: "text",
        label: "Objet du message :",
        placeholder: "Entrez votre texte...",
        required: true,
    },
    {
        id: "message",
        name: "message",
        type: "textarea",
        label: "Message :",
        placeholder: "Entrez votre texte...",
        required: true,
        rows: 6,
    },
];

const title = "Contact - Festicloze";
---

<Layout title={title}>
    <section
        class="relative h-48 md:h-64 lg:h-80 w-full overflow-hidden bg-gradient-to-b from-transparent to-[var(--color-red)]"
    >
        <Image
            src={egliseImage}
            alt="Festival Festicloze"
            class="w-full h-full object-cover opacity-60"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--color-red)]"
        >
        </div>
    </section>

    <section class="px-4 py-12 md:py-16 lg:py-20 max-w-2xl mx-auto">
        <form class="space-y-8" id="contactForm">
            {
                formFields.map((field) => (
                    <FormField
                        id={field.id}
                        name={field.name}
                        type={field.type}
                        label={field.label}
                        placeholder={field.placeholder}
                        required={field.required}
                        rows={field.rows}
                    />
                ))
            }
            <button
                type="submit"
                class="px-12 py-3 md:py-4 bg-[var(--color-yellow)] text-[var(--color-red)] font-bold rounded-full text-lg md:text-xl hover:bg-[rgba(212,175,55,0.9)] transition-colors shadow-lg hover:shadow-xl"
            >
                Envoyer
            </button>
        </form>
    </section>
</Layout>

<div class="h-12 md:h-16"></div>

<script>
    const form = document.getElementById("contactForm") as HTMLFormElement;

    if (form) {
        form.addEventListener("submit", async (e: SubmitEvent) => {
            e.preventDefault();

            const formData = new FormData(form);

            const data = {
                nom_complet: formData.get("name"),
                mail: formData.get("email"),
                object: formData.get("subject"),
                message: formData.get("message"),
            };

            try {
                const response = await fetch(
                    "https://festicloze.sacha-martin.fr:443/api/collections/contact/records",
                    {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(data),
                    },
                );

                if (!response.ok) {
                    const errorData = await response.json();
                    console.error(
                        "PocketBase erreur:",
                        response.status,
                        errorData,
                    );
                    throw new Error(JSON.stringify(errorData));
                }

                alert(
                    "Merci pour votre message ! Nous vous répondrons bientôt.",
                );
                form.reset();
            } catch (error) {
                console.error("Erreur:", error);
                alert(
                    "Une erreur est survenue lors de l'envoi. Veuillez réessayer.",
                );
            }
        });
    }
</script>
