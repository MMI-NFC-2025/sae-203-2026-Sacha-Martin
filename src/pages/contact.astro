---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Festicloze">
  <!-- Hero Section -->
  <section class="bg-burgundy py-16 md:py-24">
    <div class="container mx-auto px-4 md:px-6 text-center">
      <h1 class="text-cream mb-4">Contact</h1>
      <p class="text-cream/70 text-lg max-w-2xl mx-auto">
        Une question ? N'hesitez pas a nous contacter.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="container mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <!-- Contact Form -->
        <div class="bg-white p-8 rounded-lg shadow-md">
          <h2 class="text-burgundy text-2xl font-bold mb-6">Envoyez-nous un message</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-dark/80 font-medium mb-2">Nom complet</label>
              <input 
                type="text" 
                id="name" 
                name="name"
                required
                class="w-full px-4 py-3 border border-dark/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-all"
                placeholder="Votre nom"
              />
            </div>
            <div>
              <label for="email" class="block text-dark/80 font-medium mb-2">Adresse e-mail</label>
              <input 
                type="email" 
                id="email" 
                name="email"
                required
                class="w-full px-4 py-3 border border-dark/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-all"
                placeholder="votre@email.com"
              />
            </div>
            <div>
              <label for="subject" class="block text-dark/80 font-medium mb-2">Objet du message</label>
              <select 
                id="subject" 
                name="subject"
                required
                class="w-full px-4 py-3 border border-dark/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-all bg-white"
              >
                <option value="">Selectionnez un sujet</option>
                <option value="billetterie">Billetterie</option>
                <option value="programme">Programme</option>
                <option value="partenariat">Partenariat</option>
                <option value="presse">Presse</option>
                <option value="autre">Autre</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-dark/80 font-medium mb-2">Message</label>
              <textarea 
                id="message" 
                name="message"
                rows="5"
                required
                class="w-full px-4 py-3 border border-dark/20 rounded-lg focus:outline-none focus:ring-2 focus:ring-gold focus:border-transparent transition-all resize-none"
                placeholder="Votre message..."
              ></textarea>
            </div>
            <button 
              type="submit"
              class="w-full btn-primary text-center"
            >
              Envoyer le message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div class="space-y-8">
          <div>
            <h2 class="text-burgundy text-2xl font-bold mb-6">Informations de contact</h2>
            <div class="space-y-6">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-burgundy/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-burgundy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-burgundy font-semibold">Adresse</h3>
                  <p class="text-dark/70">
                    Office de Tourisme<br />
                    1 rue Henri Mouhot<br />
                    25200 Montbeliard, France
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-burgundy/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-burgundy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-burgundy font-semibold">E-mail</h3>
                  <a href="mailto:contact@festicloze.fr" class="text-gold hover:text-burgundy transition-colors">
                    contact@festicloze.fr
                  </a>
                </div>
              </div>
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 bg-burgundy/10 rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-6 h-6 text-burgundy" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                  </svg>
                </div>
                <div>
                  <h3 class="text-burgundy font-semibold">Telephone</h3>
                  <a href="tel:+33381941234" class="text-gold hover:text-burgundy transition-colors">
                    +33 3 81 94 12 34
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Social Media -->
          <div>
            <h3 class="text-burgundy font-semibold mb-4">Suivez-nous</h3>
            <div class="flex gap-4">
              <a href="#" class="w-12 h-12 bg-burgundy rounded-full flex items-center justify-center text-cream hover:bg-gold hover:text-dark transition-colors" aria-label="Facebook">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/>
                </svg>
              </a>
              <a href="#" class="w-12 h-12 bg-burgundy rounded-full flex items-center justify-center text-cream hover:bg-gold hover:text-dark transition-colors" aria-label="Instagram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12,2.16c3.2,0,3.58,0,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s0,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58,0-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s0-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.18,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33,0,7.05.07c-4.35.2-6.78,2.62-7,7C0,8.33,0,8.74,0,12s0,3.67.07,4.95c.2,4.36,2.62,6.78,7,7C8.33,24,8.74,24,12,24s3.67,0,4.95-.07c4.35-.2,6.78-2.62,7-7C24,15.67,24,15.26,24,12s0-3.67-.07-4.95c-.2-4.35-2.62-6.78-7-7C15.67,0,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/>
                </svg>
              </a>
              <a href="#" class="w-12 h-12 bg-burgundy rounded-full flex items-center justify-center text-cream hover:bg-gold hover:text-dark transition-colors" aria-label="TikTok">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19.59,6.69a4.83,4.83,0,0,1-3.77-4.25V2h-3.45V15.94a2.91,2.91,0,0,1-5.14,1.9,2.91,2.91,0,0,1,4.31-3.81V10.5a6.84,6.84,0,0,0-1-.08,6.34,6.34,0,0,0-5,10.32A6.34,6.34,0,0,0,16,15.94V9.23a8.16,8.16,0,0,0,4.77,1.52V7.3A4.85,4.85,0,0,1,19.59,6.69Z"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Map Placeholder -->
          <div class="bg-dark/10 rounded-lg h-48 flex items-center justify-center">
            <div class="text-center text-dark/60">
              <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
              </svg>
              <p class="text-sm">Carte de localisation</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
