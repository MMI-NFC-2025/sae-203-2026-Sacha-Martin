---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="A propos">
  <Header />
  
  <!-- Titre -->
  <section class="bg-rouge text-blanc text-center py-12 px-4">
    <h2 class="text-3xl font-bold">A propos</h2>
  </section>

  <!-- Contenu -->
  <section class="py-12 px-4 bg-gris">
    <div class="max-w-3xl mx-auto">
      
      <!-- Histoire -->
      <div class="bg-blanc p-6 mb-8">
        <h3 class="text-2xl font-bold text-rouge mb-4">Notre histoire</h3>
        <p class="mb-4">
          Ne en 2015 de la passion d'un groupe de musiciens et d'amateurs de musique baroque, 
          Festicloze est devenu au fil des annees un rendez-vous incontournable de la scene musicale regionale.
        </p>
        <p>
          Chaque annee, pendant les quatre jours precedant Noel, le festival transforme 
          Montbeliard en un ecrin de musique baroque.
        </p>
      </div>
      
      <!-- Lieux -->
      <div class="bg-blanc p-6 mb-8">
        <h3 class="text-2xl font-bold text-rouge mb-4">Les lieux</h3>
        <ul class="list-disc list-inside">
          <li class="mb-2">Temple Saint-Martin</li>
          <li class="mb-2">Eglise Saint-Maimboeuf</li>
          <li class="mb-2">Chateau des Ducs</li>
        </ul>
      </div>
      
      <!-- Image -->
      <div>
        <img src="/images/montbeliard.jpg" alt="Montbeliard" class="w-full h-64 object-cover">
      </div>
      
    </div>
  </section>

  <Footer />
</Layout>
