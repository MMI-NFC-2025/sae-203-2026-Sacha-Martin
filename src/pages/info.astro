---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import templeImage from "../assets/img/temple.avif";
import InfoCard from "../components/InfoCard.astro";
import PartnerCard from "../components/PartnerCard.astro";

const infoPratiques = [
    {
        title: "Tarifs",
        description: "À partir de 15€ • Tarif famille disponible",
    },
    {
        title: "Transport",
        description: "Parking gratuit • Navettes entre les lieux",
    },
    {
        title: "Hébergement",
        description: "Partenariats hôtels • Offres spéciales",
    },
];

const partenaires = [
    {
        name: "Ville de Montbéliard",
    },
    {
        name: "Région Bourgogne-Franche-Comté",
    },
    {
        name: "Office de Tourisme",
    },
    {
        name: "Conservatoire",
    },
];

const title = "Infos pratiques - Festicloze";
---

<Layout title={title}>
    <section
        class="relative h-48 md:h-64 lg:h-80 w-full overflow-hidden bg-gradient-to-b from-transparent to-[var(--color-red)]"
    >
        <Image
            src={templeImage}
            alt="Festival Festicloze"
            class="w-full h-full object-cover opacity-60"
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--color-red)]"
        >
        </div>
    </section>

    <section class="px-4 py-12 md:py-16 lg:py-20 max-w-6xl mx-auto">
        <h2
            class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-center text-[var(--color-text)] mb-12"
        >
            Infos pratiques
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            {
                infoPratiques.map((info) => (
                    <InfoCard
                        title={info.title}
                        description={info.description}
                    />
                ))
            }
        </div>
    </section>

    <div class="h-px bg-[rgba(212,175,55,0.3)]"></div>

    <section
        class="bg-[var(--color-bright-red)] px-4 py-12 md:py-16 lg:py-20 max-w-6xl mx-auto"
    >
        <h2
            class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-center text-[var(--color-text)] mb-12"
        >
            Nos partenaires
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {
                partenaires.map((partenaire) => (
                    <PartnerCard name={partenaire.name} />
                ))
            }
        </div>
    </section>

    <div class="h-12 md:h-16"></div>
</Layout>
