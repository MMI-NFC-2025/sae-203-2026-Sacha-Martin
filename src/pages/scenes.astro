---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { scenesName } from "../../backend/backend.mjs";

const PB_URL = "https://festicloze.sacha-martin.fr:443";

let scenes: any[] = [];

try {
    const records = await scenesName();
    scenes = records.map((scene: any) => ({
        id: scene.id,
        name: scene.nom_scene,
        genre: scene.genre_scene,
        photoUrl: scene.photo_scene
            ? `${PB_URL}/api/files/scene/${scene.id}/${scene.photo_scene}`
            : null,
        href: `/scenes/${scene.id}/`,
    }));
} catch (error) {
    console.error("Erreur lors de la récupération des scènes:", error);
}

const genres = [...new Set(scenes.map((s) => s.genre).filter(Boolean))];

const title = "Scènes - Festicloze";
---

<Layout title={title}>
    <main class="min-h-screen bg-[var(--color-red)]">
        <section
            class="h-[140px] relative bg-[url('/src/assets/img/fond.avif')] bg-center bg-cover border-b border-[#D4AF37]/30"
        >
            <div class="absolute inset-0 bg-[#8B1538]/60 backdrop-blur-[1px]">
            </div>
        </section>

        <section class="py-12 md:py-16 px-4 bg-[var(--color-red)]">
            <div class="max-w-6xl mx-auto">
                <h1
                    class="text-4xl md:text-5xl font-serif font-bold text-white text-center mb-8"
                >
                    Lieux emblématiques
                </h1>

                <div
                    class="flex flex-wrap justify-center gap-3 mb-10"
                    id="genre-filters"
                >
                    <button
                        class="filter-btn active px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-[var(--color-yellow)] text-[var(--color-red)]"
                        data-genre="all"
                    >
                        Tous
                    </button>
                    {
                        genres.map((genre) => (
                            <button
                                class="filter-btn px-4 py-2 rounded-full text-sm font-semibold transition-all duration-300 bg-white/20 text-white hover:bg-[var(--color-yellow)] hover:text-[var(--color-red)]"
                                data-genre={genre}
                            >
                                {genre}
                            </button>
                        ))
                    }
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                    {
                        scenes.map((scene) => (
                            <a
                                href={scene.href}
                                class="scene-card group no-underline transform transition-all duration-300 hover:scale-105"
                                data-genre={scene.genre || ""}
                            >
                                <div class="rounded-2xl overflow-hidden shadow-xl bg-white">
                                    <div class="relative h-48 md:h-56 w-full overflow-hidden bg-gray-300">
                                        {scene.photoUrl && (
                                            <img
                                                src={scene.photoUrl}
                                                alt={scene.name}
                                                class="w-full h-full object-cover group-hover:brightness-90 transition-all duration-300"
                                            />
                                        )}
                                    </div>

                                    <div class="p-5 md:p-6 bg-[var(--color-beige)]">
                                        <h3 class="text-lg md:text-xl font-serif font-bold text-[var(--color-dark)] mb-2">
                                            {scene.name}
                                        </h3>
                                        <p class="text-sm text-[var(--color-dark)]/80 leading-relaxed">
                                            {scene.genre}
                                        </p>
                                    </div>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const cards = document.querySelectorAll(".scene-card");

    buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
            buttons.forEach((b) => {
                b.classList.remove("active");
                b.classList.remove(
                    "bg-[var(--color-yellow)]",
                    "text-[var(--color-red)]",
                );
                b.classList.add("bg-white/20", "text-white");
            });
            btn.classList.add("active");
            btn.classList.remove("bg-white/20", "text-white");
            btn.classList.add(
                "bg-[var(--color-yellow)]",
                "text-[var(--color-red)]",
            );

            const genre = btn.getAttribute("data-genre");

            cards.forEach((card) => {
                if (
                    genre === "all" ||
                    card.getAttribute("data-genre") === genre
                ) {
                    (card as HTMLElement).style.display = "";
                } else {
                    (card as HTMLElement).style.display = "none";
                }
            });
        });
    });
</script>
