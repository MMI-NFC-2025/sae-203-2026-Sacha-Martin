---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import egliseImg from "../assets/img/eglise.avif";
import chateauImg from "../assets/img/chateau.avif";
import templeImg from "../assets/img/temple.avif";

// Interface pour typage (prête pour PocketBase)
interface Scene {
    id: string;
    name: string;
    description: string;
    image: ImageMetadata;
    href?: string;
}

// Données locales (sera remplacé par PocketBase fetch)
const scenes: Scene[] = [
    {
        id: "1",
        name: "Église Saint-Maimbœuf",
        description: "Architecture gothique • Acoustique exceptionnelle",
        image: egliseImg,
        href: "/scene/1",
    },
    {
        id: "2",
        name: "Château des Ducs",
        description: "Monument historique • Cadre majestueux",
        image: chateauImg,
        href: "/scene/2",
    },
    {
        id: "3",
        name: "Temple Saint-Martin",
        description: "Orgue historique • Intimité baroque",
        image: templeImg,
        href: "/scene/3",
    },
];

// TODO: Fonction pour charger depuis PocketBase
// async function getScenes() {
//     const pb = new PocketBase('YOUR_POCKETBASE_URL');
//     const records = await pb.collection('scenes').getList();
//     return records.items;
// }
---

<Layout title="Scènes - Festicloze">
    <main class="min-h-screen bg-[var(--color-red)]">
        <!-- Hero Section -->
        <section
            class="h-[140px] relative bg-[url('/src/assets/img/fond.avif')] bg-center bg-cover border-b border-[#D4AF37]/30"
        >
            <div class="absolute inset-0 bg-[#8B1538]/60 backdrop-blur-[1px]">
            </div>
        </section>

        <!-- Scenes Section -->
        <section class="py-12 md:py-16 px-4 bg-[var(--color-red)]">
            <div class="max-w-6xl mx-auto">
                <!-- Titre -->
                <h1 class="text-4xl md:text-5xl font-serif font-bold text-white text-center mb-12">
                    Lieux emblématiques
                </h1>

                <!-- Grille responsive -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                    {
                        scenes.map((scene) => (
                            <a
                                href={scene.href}
                                class="group no-underline transform transition-all duration-300 hover:scale-105"
                            >
                                <div class="rounded-2xl overflow-hidden shadow-xl bg-white">
                                    <!-- Image -->
                                    <div class="relative h-48 md:h-56 w-full overflow-hidden">
                                        <Image
                                            src={scene.image}
                                            alt={scene.name}
                                            class="w-full h-full object-cover group-hover:brightness-90 transition-all duration-300"
                                        />
                                    </div>

                                    <!-- Info Card -->
                                    <div class="p-5 md:p-6 bg-[var(--color-beige)]">
                                        <h3 class="text-lg md:text-xl font-serif font-bold text-[var(--color-dark)] mb-2">
                                            {scene.name}
                                        </h3>
                                        <p class="text-sm text-[var(--color-dark)]/80 leading-relaxed">
                                            {scene.description}
                                        </p>
                                    </div>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>

<style>
    /* Styles additionnels optionnels */
</style>
