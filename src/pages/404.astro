---
import Layout from "../layouts/Layout.astro";

const title = "404 - Page non trouvée | Festicloze";
---

<Layout title={title}>
    <main
        class="min-h-[60vh] flex items-center justify-center px-4 py-16 md:py-24"
    >
        <section class="text-center max-w-lg mx-auto">
            <h1
                class="text-7xl md:text-9xl font-serif font-bold text-[var(--color-yellow)] mb-4"
            >
                404
            </h1>
            <h2
                class="text-2xl md:text-4xl font-serif font-bold text-[var(--color-text)] mb-4"
            >
                Page non trouvée
            </h2>
            <p
                class="text-sm md:text-base text-[var(--color-text)] opacity-80 mb-10"
            >
                Désolé, la page que vous recherchez n'existe pas ou a été
                déplacée.
            </p>
            <a
                href="/"
                class="inline-block px-10 py-3 md:py-4 bg-[var(--color-yellow)] text-[var(--color-red)] font-bold rounded-full text-base md:text-lg hover:bg-[rgba(212,175,55,0.9)] transition-colors shadow-lg"
            >
                Retour à l'accueil
            </a>
        </section>
    </main>
</Layout>
