---
import Layout from "../../layouts/Layout.astro";
import BackButton from "../../components/BackButton.astro";
import { artisteID, sceneID } from "../../../backend/backend.mjs";

const PB_URL = "https://festicloze.sacha-martin.fr:443";

const { id } = Astro.params;

// Récupère l'artiste depuis PocketBase
let artist: any = null;

try {
    artist = await artisteID(id);
} catch (error) {
    console.error("Erreur lors de la récupération de l'artiste:", error);
}

if (!artist) {
    return Astro.redirect("/artistes/");
}

const photoUrl = artist.photo_artiste
    ? `${PB_URL}/api/files/artiste/${artist.id}/${artist.photo_artiste}`
    : null;

let nomScene = artist.scene || "";
try {
    if (artist.scene) {
        const sceneData = await sceneID(artist.scene);
        nomScene = sceneData.nom_scene;
    }
} catch (error) {
    console.error("Erreur récupération scène:", error);
}

function formatDate(date: string) {
    const d = new Date(date);
    const jour = d.toLocaleDateString("fr-FR", {
        weekday: "long",
        day: "numeric",
        month: "long",
    });
    const heure = d.toLocaleTimeString("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    });
    return `${jour} à ${heure}`;
}

const galleryPhotos =
    artist.galerie_artiste?.map((filename: string) => ({
        id: filename,
        alt: `Photo de ${artist.nom_artiste}`,
        url: `${PB_URL}/api/files/artiste/${artist.id}/${filename}`,
    })) || [];

const title = `${artist.nom_artiste} - Festicloze`;
---

<Layout title={title}>
    <section
        class="relative h-48 md:h-64 lg:h-80 w-full overflow-hidden bg-gradient-to-b from-transparent to-[var(--color-red)]"
    >
        {
            photoUrl && (
                <img
                    src={photoUrl}
                    alt={artist.nom_artiste}
                    class="w-full h-full object-cover opacity-60"
                />
            )
        }
        <div
            class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--color-red)]"
        >
        </div>
    </section>

    <section class="px-4 py-12 md:py-16 lg:py-20 max-w-6xl mx-auto">
        <h2
            class="text-3xl md:text-4xl lg:text-5xl font-serif font-bold text-center text-[var(--color-text)] mb-2"
        >
            {artist.nom_artiste}
        </h2>
        <p
            class="text-center text-lg md:text-xl font-sans text-[var(--color-yellow)] mb-6"
        >
            {artist.genre_artiste}
        </p>
        <p
            class="text-center text-base md:text-lg text-[var(--color-text)] max-w-3xl mx-auto mb-8"
        >
            {artist.description_artiste}
        </p>
    </section>

    <section class="px-4 py-8 md:py-12 lg:py-16 max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12 mb-12">
            <div class="lg:col-span-1">
                <div class="rounded-lg overflow-hidden shadow-lg">
                    {
                        photoUrl && (
                            <img
                                src={photoUrl}
                                alt={artist.nom_artiste}
                                class="w-full h-auto object-cover"
                            />
                        )
                    }
                </div>
            </div>

            <div class="lg:col-span-2 space-y-8">
                <div
                    class="bg-[var(--color-beige)] border border-[rgba(212,175,55,0.3)] rounded-lg p-6 md:p-8 shadow-md"
                >
                    <h3
                        class="text-xl md:text-2xl font-sans font-bold text-[#8B1538] mb-4"
                    >
                        À propos
                    </h3>
                    <p
                        class="text-base md:text-lg text-[var(--color-red)] leading-relaxed"
                    >
                        {artist.description_artiste}
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    {
                        artist.date_representation && (
                            <div class="bg-[var(--color-beige)] border border-[rgba(212,175,55,0.3)] rounded-lg p-6 shadow-md">
                                <h3 class="text-lg md:text-xl font-sans font-bold text-[#8B1538] mb-4">
                                    Dates
                                </h3>
                                <p class="text-base text-[var(--color-red)]">
                                    {formatDate(artist.date_representation)}
                                </p>
                            </div>
                        )
                    }

                    {
                        artist.scene && (
                            <div class="bg-[var(--color-beige)] border border-[rgba(212,175,55,0.3)] rounded-lg p-6 shadow-md">
                                <h3 class="text-lg md:text-xl font-sans font-bold text-[#8B1538] mb-4">
                                    Scène
                                </h3>
                                <p class="text-base text-[var(--color-red)]">
                                    {nomScene}
                                </p>
                            </div>
                        )
                    }
                </div>
            </div>
        </div>

        <div class="h-px bg-[rgba(212,175,55,0.3)] mb-12 md:mb-16"></div>

        {
            galleryPhotos.length > 0 && (
                <div>
                    <h3 class="text-2xl md:text-3xl font-serif font-bold text-center text-[var(--color-text)] mb-8">
                        Galerie photos
                    </h3>
                    <div
                        class="relative overflow-hidden rounded-2xl shadow-lg"
                        id="gallery-carousel"
                    >
                        <div
                            class="flex transition-transform duration-500 ease-in-out"
                            id="gallery-track"
                        >
                            {galleryPhotos.map((photo: any) => (
                                <div class="w-full flex-shrink-0">
                                    <img
                                        src={photo.url}
                                        alt={photo.alt}
                                        class="w-full h-64 md:h-96 object-cover"
                                    />
                                </div>
                            ))}
                        </div>

                        <button
                            id="gallery-prev"
                            class="absolute left-3 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white w-10 h-10 rounded-full flex items-center justify-center transition-colors"
                            aria-label="Photo précédente"
                        >
                            &#10094;
                        </button>
                        <button
                            id="gallery-next"
                            class="absolute right-3 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/70 text-white w-10 h-10 rounded-full flex items-center justify-center transition-colors"
                            aria-label="Photo suivante"
                        >
                            &#10095;
                        </button>

                        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2">
                            {galleryPhotos.map((_: any, i: number) => (
                                <button
                                    class:list={[
                                        "gallery-dot w-3 h-3 rounded-full transition-colors",
                                        i === 0 ? "bg-white" : "bg-white/50",
                                    ]}
                                    data-index={i}
                                    aria-label={`Photo ${i + 1}`}
                                />
                            ))}
                        </div>
                    </div>
                </div>
            )
        }
    </section>

    <section class="px-4 py-8 max-w-6xl mx-auto">
        <BackButton href="/artistes/" label="Retour aux artistes" />
    </section>

    <div class="h-12 md:h-16"></div>
</Layout>

<script>
    const track = document.getElementById("gallery-track");
    const prevBtn = document.getElementById("gallery-prev");
    const nextBtn = document.getElementById("gallery-next");
    const dots = document.querySelectorAll(".gallery-dot");

    if (track && prevBtn && nextBtn) {
        const slides = track.children.length;
        let current = 0;

        function goTo(index: number) {
            current = (index + slides) % slides;
            track!.style.transform = `translateX(-${current * 100}%)`;
            dots.forEach((dot, i) => {
                dot.classList.toggle("bg-white", i === current);
                dot.classList.toggle("bg-white/50", i !== current);
            });
        }

        prevBtn.addEventListener("click", () => goTo(current - 1));
        nextBtn.addEventListener("click", () => goTo(current + 1));
        dots.forEach((dot) => {
            dot.addEventListener("click", () => {
                goTo(Number(dot.getAttribute("data-index")));
            });
        });
    }
</script>
