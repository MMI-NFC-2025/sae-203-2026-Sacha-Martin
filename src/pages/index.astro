---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Cardstat from "../components/Cardstat.astro";
import Button from "../components/Button.astro";
import Carousel from "../components/Carousel.astro";
import MapIcon from "../assets/icons/maps.svg";
import ArtistesIcon from "../assets/icons/artistes.svg";
import MusiqueIcon from "../assets/icons/musique.svg";

const festivalStats = [
	{ icon: MapIcon, val: "3", txt: "Concerts" },
	{ icon: ArtistesIcon, val: "3", txt: "Artistes" },
	{ icon: MusiqueIcon, val: "3", txt: "Scènes" },
];
---

<Layout>
	<Hero />
	<section class="flex justify-center py-8 px-3 relative z-[6]">
		<div class="flex gap-8 items-center w-full justify-center">
			{
				festivalStats.map((stat) => (
					<Cardstat
						iconPath={stat.icon}
						value={stat.val}
						label={stat.txt}
					/>
				))
			}
		</div>
	</section>
	<Button />
	<Carousel />
</Layout>
