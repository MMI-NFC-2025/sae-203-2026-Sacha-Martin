---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Festicloze">
  <Header />
  
  <!-- Hero Section -->
  <section class="bg-rouge text-blanc text-center py-20 px-4">
    <h1 class="text-4xl md:text-6xl font-bold mb-4">Festicloze</h1>
    <p class="text-or text-xl mb-2">La magie de Noel au coeur</p>
    <p class="text-or text-xl mb-6">de la musique baroque</p>
    <p class="mb-8">20 - 23 Decembre 2025 | Montbeliard</p>
    
    <!-- Stats -->
    <div class="flex flex-wrap justify-center gap-8 mb-8">
      <div class="text-center">
        <p class="text-3xl font-bold text-or">3</p>
        <p class="text-sm">jours de concerts</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold text-or">10+</p>
        <p class="text-sm">artistes</p>
      </div>
      <div class="text-center">
        <p class="text-3xl font-bold text-or">3</p>
        <p class="text-sm">lieux</p>
      </div>
    </div>
    
    <a href="/billetterie" class="bg-or text-noir px-6 py-3 font-bold inline-block hover:bg-blanc">
      Reserver mes places
    </a>
  </section>

  <!-- Carousel / Images -->
  <section class="py-12 px-4 bg-gris">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <img src="/images/hero-baroque.jpg" alt="Concert 1" class="w-full h-48 object-cover">
        <img src="/images/ensemble-baroque.jpg" alt="Concert 2" class="w-full h-48 object-cover">
        <img src="/images/soprano.jpg" alt="Concert 3" class="w-full h-48 object-cover">
      </div>
    </div>
  </section>

  <Footer />
</Layout>
