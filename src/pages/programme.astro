---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Programme">
  <Header />
  
  <!-- Titre -->
  <section class="bg-rouge text-blanc text-center py-12 px-4">
    <h2 class="text-3xl font-bold">Programme</h2>
    <p class="mt-2">20 - 23 Decembre 2025</p>
  </section>

  <!-- Programme -->
  <section class="py-12 px-4 bg-gris">
    <div class="max-w-3xl mx-auto">
      
      <!-- Jour 1 -->
      <div class="mb-8">
        <div class="bg-rouge text-blanc p-4 mb-4">
          <h3 class="text-2xl font-bold">20 Decembre</h3>
          <p>Samedi - Concert d'ouverture</p>
        </div>
        <div class="bg-blanc p-4 mb-2">
          <p class="text-or font-bold">19h00</p>
          <p class="font-bold">Concert d'ouverture - Cantates de Noel</p>
          <p class="text-sm">Temple Saint-Martin</p>
        </div>
      </div>
      
      <!-- Jour 2 -->
      <div class="mb-8">
        <div class="bg-rouge text-blanc p-4 mb-4">
          <h3 class="text-2xl font-bold">21 Decembre</h3>
          <p>Dimanche - Soiree baroque</p>
        </div>
        <div class="bg-blanc p-4 mb-2">
          <p class="text-or font-bold">17h00</p>
          <p class="font-bold">Concert jeune public</p>
          <p class="text-sm">Salle des fetes</p>
        </div>
        <div class="bg-blanc p-4 mb-2">
          <p class="text-or font-bold">19h30</p>
          <p class="font-bold">Les Quatre Saisons de Vivaldi</p>
          <p class="text-sm">Eglise Saint-Maimboeuf</p>
        </div>
      </div>
      
      <!-- Jour 3 -->
      <div class="mb-8">
        <div class="bg-rouge text-blanc p-4 mb-4">
          <h3 class="text-2xl font-bold">22 Decembre</h3>
          <p>Lundi - Nuit des etoiles</p>
        </div>
        <div class="bg-blanc p-4 mb-2">
          <p class="text-or font-bold">20h00</p>
          <p class="font-bold">Concert aux chandelles</p>
          <p class="text-sm">Eglise Saint-Maimboeuf</p>
        </div>
      </div>
      
      <!-- Jour 4 -->
      <div class="mb-8">
        <div class="bg-rouge text-blanc p-4 mb-4">
          <h3 class="text-2xl font-bold">23 Decembre</h3>
          <p>Mardi - Concert de cloture</p>
        </div>
        <div class="bg-blanc p-4 mb-2">
          <p class="text-or font-bold">19h00</p>
          <p class="font-bold">Grand concert de cloture</p>
          <p class="text-sm">Eglise Saint-Maimboeuf</p>
        </div>
      </div>
      
    </div>
  </section>

  <Footer />
</Layout>
