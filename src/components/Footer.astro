---
const socialLinks = [
  { href: "#", icon: "facebook", label: "Facebook" },
  { href: "#", icon: "instagram", label: "Instagram" },
  { href: "#", icon: "tiktok", label: "TikTok" },
];

const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/artistes", label: "Artistes" },
  { href: "/programme", label: "Programme" },
  { href: "/apropos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];
---

<footer class="bg-burgundy text-cream">
  <div class="container mx-auto px-4 md:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Logo et Description -->
      <div class="space-y-4">
        <div class="flex items-center gap-2">
          <img src="/images/logo.svg" alt="Festicloze" class="h-10 w-auto" />
          <span class="text-2xl font-bold">Festicloze</span>
        </div>
        <p class="text-cream/80 text-sm">
          La magie de Noel au coeur de la musique baroque. 
          Du 20 au 23 decembre 2025 a Montbeliard.
        </p>
        <!-- Reseaux sociaux -->
        <div class="flex gap-4 pt-2">
          <a href="#" class="text-cream hover:text-gold transition-colors" aria-label="Facebook">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.77,7.46H14.5v-1.9c0-.9.6-1.1,1-1.1h3V.5h-4.33C10.24.5,9.5,3.44,9.5,5.32v2.15h-3v4h3v12h5v-12h3.85l.42-4Z"/>
            </svg>
          </a>
          <a href="#" class="text-cream hover:text-gold transition-colors" aria-label="Instagram">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12,2.16c3.2,0,3.58,0,4.85.07,3.25.15,4.77,1.69,4.92,4.92.06,1.27.07,1.65.07,4.85s0,3.58-.07,4.85c-.15,3.23-1.66,4.77-4.92,4.92-1.27.06-1.65.07-4.85.07s-3.58,0-4.85-.07c-3.26-.15-4.77-1.7-4.92-4.92-.06-1.27-.07-1.65-.07-4.85s0-3.58.07-4.85C2.38,3.92,3.9,2.38,7.15,2.23,8.42,2.18,8.8,2.16,12,2.16ZM12,0C8.74,0,8.33,0,7.05.07c-4.35.2-6.78,2.62-7,7C0,8.33,0,8.74,0,12s0,3.67.07,4.95c.2,4.36,2.62,6.78,7,7C8.33,24,8.74,24,12,24s3.67,0,4.95-.07c4.35-.2,6.78-2.62,7-7C24,15.67,24,15.26,24,12s0-3.67-.07-4.95c-.2-4.35-2.62-6.78-7-7C15.67,0,15.26,0,12,0Zm0,5.84A6.16,6.16,0,1,0,18.16,12,6.16,6.16,0,0,0,12,5.84ZM12,16a4,4,0,1,1,4-4A4,4,0,0,1,12,16ZM18.41,4.15a1.44,1.44,0,1,0,1.44,1.44A1.44,1.44,0,0,0,18.41,4.15Z"/>
            </svg>
          </a>
          <a href="#" class="text-cream hover:text-gold transition-colors" aria-label="TikTok">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59,6.69a4.83,4.83,0,0,1-3.77-4.25V2h-3.45V15.94a2.91,2.91,0,0,1-5.14,1.9,2.91,2.91,0,0,1,4.31-3.81V10.5a6.84,6.84,0,0,0-1-.08,6.34,6.34,0,0,0-5,10.32A6.34,6.34,0,0,0,16,15.94V9.23a8.16,8.16,0,0,0,4.77,1.52V7.3A4.85,4.85,0,0,1,19.59,6.69Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-gold font-bold mb-4">Navigation</h3>
        <nav class="flex flex-col gap-2">
          {navLinks.map((link) => (
            <a href={link.href} class="text-cream/80 hover:text-gold transition-colors">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-gold font-bold mb-4">Contact</h3>
        <div class="space-y-2 text-cream/80 text-sm">
          <p>Montbeliard, France</p>
          <p>20 - 23 Decembre 2025</p>
          <a href="mailto:contact@festicloze.fr" class="hover:text-gold transition-colors">
            contact@festicloze.fr
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gold/20 mt-8 pt-8 text-center text-cream/60 text-sm">
      <p>&copy; 2025 Festicloze. Tous droits reserves.</p>
    </div>
  </div>
</footer>
