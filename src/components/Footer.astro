---
import { Image } from "astro:assets";
import Logo from "../assets/icons/logo.svg";
import Facebook from "../assets/icons/facebook.svg";
import Instagram from "../assets/icons/insta.svg";
import TikTok from "../assets/icons/tiktok.svg";
---

<footer
    class="p-0 border-y-4 border-[var(--color-yellow)] text-[var(--color-text)]"
>
    <div class="text-center py-10 px-4">
        <h3 class="text-2xl mb-2 font-bold">Festicloze</h3>
        <p class="text-sm mb-8">La musique du cœur de Noël</p>

        <div class="mb-7">
            <h4 class="text-sm font-semibold mb-3">Contact</h4>
            <a
                href="mailto:contact@festicloze.fr"
                class="text-inherit no-underline text-sm hover:underline"
                >contact@festicloze.fr</a
            >
            <p class="text-sm mt-1.5">06 12 34 56 78</p>
        </div>

        <div class="mb-7">
            <h4 class="text-sm font-semibold mb-3">Suivez-nous</h4>
            <div class="flex justify-center gap-4 m-0">
                <a href="#" aria-label="Facebook"
                    ><Facebook class="w-6 h-6" aria-label="Facebook" /></a
                >
                <a href="#" aria-label="Instagram"
                    ><Instagram class="w-6 h-6" aria-label="Instagram" /></a
                >
                <a href="#" aria-label="TikTok"
                    ><TikTok class="w-6 h-6" aria-label="TikTok" /></a
                >
            </div>
        </div>

        <div class="pt-6 border-t-2 border-[var(--bright-yellow)]">
            <p class="text-xs mt-0.5 opacity-90">© 2025 Festicloze</p>
        </div>
    </div>
</footer>
