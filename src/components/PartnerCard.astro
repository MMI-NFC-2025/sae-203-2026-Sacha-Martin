---
interface Props {
    name: string;
}

const { name } = Astro.props;
---

<div
    class="bg-[#2D0606] border rounded-lg p-8 shadow-md hover:shadow-lg transition-shadow flex items-center justify-center min-h-28"
>
    <span
        class="text-lg md:text-xl font-sans font-bold text-[var(--color-text)] text-center"
    >
        {name}
    </span>
</div>
