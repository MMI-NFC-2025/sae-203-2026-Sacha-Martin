---
import { Image } from "astro:assets";
import Logo from "../assets/icons/logo.svg";
import MenuIcon from "../assets/icons/menu.svg";
import CloseIcon from "../assets/icons/close.svg";
---

<header class="sticky top-0 z-50 bg-[var(--color-red)] py-3">
    <div class="flex items-center justify-between px-4 md:gap-12">
        <a href="/" class="inline-flex items-center gap-2.5">
            <Logo class="h-14" />
        </a>

        <!-- Menu desktop - visible à md+ -->
        <nav class="hidden md:flex md:items-center md:justify-center md:gap-8">
            <ul class="list-none m-0 p-0 flex gap-8">
                <li>
                    <a
                        href="/programme/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        Programmes
                    </a>
                </li>
                <li>
                    <a
                        href="/artistes/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        Artistes
                    </a>
                </li>
                <li>
                    <a
                        href="/scenes/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        Scènes
                    </a>
                </li>
                <li>
                    <a
                        href="/apropos/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        À propos
                    </a>
                </li>
                <li>
                    <a
                        href="/contact/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        Contact
                    </a>
                </li>
                <li>
                    <a
                        href="/info/"
                        class="text-[var(--color-text)] no-underline text-base font-serif font-semibold hover:text-white transition-colors"
                    >
                        Infos pratiques
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Menu hamburger - visible uniquement en mobile -->
        <button
            id="menuToggle"
            class="bg-transparent border-0 p-2 text-inherit cursor-pointer md:hidden justify-self-end"
            aria-label="Ouvrir le menu"
        >
            <MenuIcon class="w-6 h-6" aria-label="Ouvrir le menu" />
        </button>
    </div>
</header>

<div
    id="menuOverlay"
    class="fixed inset-0 bg-black/50 z-[90] opacity-0 pointer-events-none transition-opacity duration-300"
>
</div>

<nav
    class="fixed inset-0 bg-[var(--color-red)] z-[100] -translate-x-full transition-transform duration-300 overflow-y-auto md:hidden"
    id="mobileMenu"
    aria-hidden="true"
>
    <div class="flex items-center justify-between gap-4 py-6 px-10">
        <a
            href="/"
            class="flex items-center gap-2.5 no-underline text-[var(--color-text)] font-serif text-lg font-bold flex-shrink-0"
        >
            <Logo class="h-24 w-auto flex-shrink-0" />
        </a>
        <button
            class="bg-transparent border-0 p-2 text-[var(--color-text)] cursor-pointer flex items-center justify-center flex-shrink-0"
            id="menuClose"
            aria-label="Fermer le menu"
        >
            <CloseIcon
                class="w-7 h-7 brightness-0 invert"
                aria-label="Fermer le menu"
            />
        </button>
    </div>

    <ul class="list-none m-0 p-0">
        <li>
            <a
                href="/programme/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                Programmes
            </a>
        </li>
        <li>
            <a
                href="/artistes/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                Artistes
            </a>
        </li>
        <li>
            <a
                href="/scene/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                Scènes
            </a>
        </li>
        <li>
            <a
                href="/apropos/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                À propos
            </a>
        </li>
        <li>
            <a
                href="/contact/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                Contact
            </a>
        </li>
        <li>
            <a
                href="/info/"
                class="block py-8 px-5 text-[var(--color-text)] no-underline text-[1.625rem] font-serif font-semibold hover:bg-white/5 transition-colors"
            >
                Infos pratiques
            </a>
        </li>
    </ul>
</nav>

<script>
    // On crée une fonction d'initialisation
    function initNavigation() {
        const openBtn = document.getElementById("menuToggle");
        const closeBtn = document.getElementById("menuClose");
        const menu = document.getElementById("mobileMenu");
        const overlay = document.getElementById("menuOverlay");

        // Sécurité : on vérifie que les éléments existent avant d'ajouter les écouteurs
        if (!openBtn || !menu || !overlay) return;

        const toggleMenu = () => {
            // 1. Faire glisser le menu (Entrée/Sortie)
            menu.classList.toggle("-translate-x-full");
            menu.classList.toggle("translate-x-0");

            // 2. Gérer l'overlay sombre
            overlay.classList.toggle("opacity-0");
            overlay.classList.toggle("opacity-100");
            overlay.classList.toggle("pointer-events-none");
            overlay.classList.toggle("pointer-events-auto");

            // 3. Bloquer le scroll du site en arrière-plan
            document.body.classList.toggle("overflow-hidden");
        };

        // Écouteurs d'événements
        openBtn.onclick = toggleMenu;
        if (closeBtn) closeBtn.onclick = toggleMenu;
        overlay.onclick = toggleMenu;

        // Fermer avec la touche Échap
        document.onkeydown = (e) => {
            if (
                e.key === "Escape" &&
                menu.classList.contains("translate-x-0")
            ) {
                toggleMenu();
            }
        };
    }

    // Lancement du script
    initNavigation();
</script>
