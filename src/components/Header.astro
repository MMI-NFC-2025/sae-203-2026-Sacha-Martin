---
const navLinks = [
  { href: "/", label: "Accueil" },
  { href: "/artistes", label: "Artistes" },
  { href: "/programme", label: "Programme" },
  { href: "/apropos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-burgundy/95 backdrop-blur-sm">
  <div class="container mx-auto px-4 md:px-6">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <img src="/images/logo.svg" alt="Festicloze" class="h-10 md:h-12 w-auto" />
        <span class="text-cream text-xl md:text-2xl font-bold">Festicloze</span>
      </a>

      <!-- Navigation Desktop -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`text-cream hover:text-gold transition-colors duration-300 ${
              currentPath === link.href ? "text-gold border-b-2 border-gold" : ""
            }`}
          >
            {link.label}
          </a>
        ))}
        <a href="/billetterie" class="btn-primary">Billetterie</a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden text-cream p-2"
        aria-label="Menu"
      >
        <svg
          id="menu-icon"
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"
          />
        </svg>
        <svg
          id="close-icon"
          class="w-6 h-6 hidden"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden bg-burgundy border-t border-gold/20"
  >
    <div class="container mx-auto px-4 py-4 flex flex-col gap-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`text-cream hover:text-gold transition-colors duration-300 py-2 ${
            currentPath === link.href ? "text-gold" : ""
          }`}
        >
          {link.label}
        </a>
      ))}
      <a href="/billetterie" class="btn-primary text-center mt-2">Billetterie</a>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
    menuIcon?.classList.toggle("hidden");
    closeIcon?.classList.toggle("hidden");
  });
</script>
