---
// Header simple pour Festicloze
---

<header class="bg-rouge text-blanc p-4">
  <div class="flex justify-between items-center max-w-6xl mx-auto">
    
    <!-- Logo -->
    <a href="/" class="text-2xl font-bold text-or">Festicloze</a>
    
    <!-- Menu burger mobile -->
    <button id="menu-btn" class="md:hidden text-blanc text-2xl">
      &#9776;
    </button>
    
    <!-- Navigation desktop -->
    <nav class="hidden md:flex gap-6">
      <a href="/" class="text-blanc hover:text-or">Accueil</a>
      <a href="/artistes" class="text-blanc hover:text-or">Artistes</a>
      <a href="/programme" class="text-blanc hover:text-or">Programme</a>
      <a href="/apropos" class="text-blanc hover:text-or">A propos</a>
      <a href="/contact" class="text-blanc hover:text-or">Contact</a>
    </nav>
  </div>
  
  <!-- Menu mobile -->
  <nav id="menu-mobile" class="hidden md:hidden flex-col gap-4 mt-4 text-center">
    <a href="/" class="text-blanc hover:text-or block py-2">Accueil</a>
    <a href="/artistes" class="text-blanc hover:text-or block py-2">Artistes</a>
    <a href="/programme" class="text-blanc hover:text-or block py-2">Programme</a>
    <a href="/apropos" class="text-blanc hover:text-or block py-2">A propos</a>
    <a href="/contact" class="text-blanc hover:text-or block py-2">Contact</a>
  </nav>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu-mobile');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });
</script>
