---
interface Props {
    id: string;
    name: string;
    type?: "text" | "email" | "textarea";
    label: string;
    placeholder: string;
    required?: boolean;
    rows?: number;
}

const {
    id,
    name,
    type = "text",
    label,
    placeholder,
    required = false,
    rows = 6,
} = Astro.props;
---

<div class="form-group">
    <label
        for={id}
        class="block text-lg md:text-xl font-serif font-bold text-[var(--color-text)] mb-3"
    >
        {label}
    </label>

    {
        type === "textarea" ? (
            <textarea
                id={id}
                name={name}
                {rows}
                placeholder={placeholder}
                {required}
                class="w-full px-6 py-4 bg-transparent border-2 border-[var(--color-text)] rounded-3xl text-[var(--color-text)] placeholder-[rgba(255,246,214,0.6)] focus:outline-none focus:border-[var(--color-yellow)] transition-colors resize-none"
            />
        ) : (
            <input
                type={type}
                id={id}
                name={name}
                placeholder={placeholder}
                {required}
                class="w-full px-6 py-3 md:py-4 bg-transparent border-2 border-[var(--color-text)] rounded-full text-[var(--color-text)] placeholder-[rgba(255,246,214,0.6)] focus:outline-none focus:border-[var(--color-yellow)] transition-colors"
            />
        )
    }
</div>
