---
interface Props {
    href: string;
    label: string;
}

const { href, label } = Astro.props;
---

<a
    {href}
    class="inline-flex items-center px-6 py-3 bg-[var(--color-yellow)] text-[var(--color-red)] font-bold rounded-full hover:bg-[rgba(212,175,55,0.9)] transition-colors text-sm md:text-base"
>
    ← {label}
</a>
