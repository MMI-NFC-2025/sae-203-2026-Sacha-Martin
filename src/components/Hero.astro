---
import { Image } from "astro:assets";
---

<section
    class="min-h-[90vh] bg-[url('../assets/img/fond.avif')] bg-[center_35%] bg-cover relative flex items-center justify-center overflow-hidden"
>
    <div
        class="absolute inset-0 bg-gradient-to-b from-[var(--color-red)]/20 to-[var(--color-red)]/70 z-0 pointer-events-none"
    >
    </div>

    <div
        class="relative z-10 py-4.5 px-4 text-center max-w-[86%] text-[var(--color-text)]"
    >
        <h1
            class="font-serif text-6xl text-inherit mb-7 leading-none tracking-tight shadow-sm"
        >
            Festicloze
        </h1>

        <p class="text-base mb-8 leading-relaxed">
            <span class="inline-block">La magie de Noël au cœur</span>
            <br />de la musique baroque
        </p>

        <div
            class="inline-block bg-white/20 backdrop-blur-sm py-6 px-12 rounded-xl text-base mt-0"
        >
            <span class="block font-semibold">20 - 23 Décembre 2025</span>
            <span class="block mt-1.5 opacity-95">Montbéliard</span>
        </div>
    </div>
</section>
